{% extends 'base.html.twig' %}

{% block body %}
    <main class="container">
        <h1>Tableau de bord</h1>
        <a role="button" class="secondary" href="/dashboard">Annuler</a>
        <div class="error">{{ error }}</div>
        <form method="POST" action="/dashboard/create">
            <label for="mail">Email: *</label>
            <input id="mail" type="text" name="mail" required />
            <label for="prenom">Prénom: *</label>
            <input id="prenom" type="text" name="prenom" required />
            <label for="nom">Nom: *</label>
            <input id="nom" type="text" name="nom" required />
            <label for="telephone">Téléphone: *</label>
            <input id="telephone" type="text" name="telephone" required />
            <button type="submit">Créer un contact</button>
        </form>
    </main>
{% endblock %}